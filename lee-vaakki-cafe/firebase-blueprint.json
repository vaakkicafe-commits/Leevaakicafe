{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "A food or beverage item available at LEE VAAKKI Cafe.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the item." },
        "price": { "type": "number", "description": "The price in INR." },
        "category": { "type": "string", "description": "The category (e.g., Beverages, Burgers)." },
        "description": { "type": "string", "description": "A brief description of the item." },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL to the item's image." },
        "isFeatured": { "type": "boolean", "description": "Whether the item is featured on the home page." }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "A menu category.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The category name." },
        "order": { "type": "integer", "description": "Display order." }
      },
      "required": ["name"]
    },
    "ContactInquiry": {
      "title": "Contact Inquiry",
      "description": "A message sent via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/menuItems/{itemId}": {
      "schema": "MenuItem",
      "description": "Collection of menu items."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of menu categories."
    },
    "/inquiries/{inquiryId}": {
      "schema": "ContactInquiry",
      "description": "User inquiries from the contact form."
    }
  }
}
